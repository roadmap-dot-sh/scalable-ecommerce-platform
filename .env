# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=ecommerce

# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=secure_password

# Redis
REDIS_PASSWORD=redis_password

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=admin_password

# JWT
JWT_SECRET=your_jwt_secret_key_here_min_256_bits
JWT_EXPIRATION=86400000

# Stripe
STRIPE_API_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# SendGrid
SENDGRID_API_KEY=SG.xxxxx

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1234567890

# Service URLs
USER_SERVICE_URL=http://user-service:8081
PRODUCT_SERVICE_URL=http://product-service:8082
CART_SERVICE_URL=http://cart-service:8083
ORDER_SERVICE_URL=http://order-service:8084
PAYMENT_SERVICE_URL=http://payment-service:8085
NOTIFICATION_SERVICE_URL=http://notification-service:8086

# Monitoring
